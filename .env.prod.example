# Secretos de PRODUCCIÓN. Copia a .env.prod (NUNCA lo commitees) junto a docker-compose.prod.yml.
# Genera secretos largos y aleatorios, p. ej.:  openssl rand -hex 32

POSTGRES_USER=freetoolkit
POSTGRES_PASSWORD=cambia-esta-password-larga
POSTGRES_DB=freetoolkit

JWT_ACCESS_SECRET=genera-un-secreto-de-64-hex
JWT_REFRESH_SECRET=genera-otro-secreto-de-64-hex
TZ_REFERENCE=America/Lima

# Puerto público del sitio (80 por defecto)
WEB_PORT=80

# Pasarelas reales (opcional; vacío = modo simulado)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
MERCADOPAGO_ACCESS_TOKEN=
