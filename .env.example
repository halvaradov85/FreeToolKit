# Copia este archivo a .env y rellena los valores. NUNCA commitees .env.
DATABASE_URL="postgresql://freetoolkit:freetoolkit@localhost:5432/freetoolkit?schema=public"

# Servidor
PORT=3000
NODE_ENV=development

# Auth (genera secretos largos y aleatorios)
JWT_ACCESS_SECRET="cambia-esto-por-un-secreto-largo"
JWT_REFRESH_SECRET="cambia-esto-por-otro-secreto-largo"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# Zona horaria de referencia para el reinicio de cupos diarios
TZ_REFERENCE="America/Lima"

# Pagos (sandbox) — usados en fases posteriores (US4)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
MERCADOPAGO_ACCESS_TOKEN=""

# Proveedores de terceros (US2) — opcionales en el MVP
PROVIDER_TRANSLATE_KEY=""
PROVIDER_REMOVEBG_KEY=""
